# ── Backend (Fastify) ────────────────────────────────
DATABASE_URL=postgresql://fintrack:fintrack@localhost:5432/fintrack
PORT=3000

# Origem do frontend (ou * em dev)
CORS_ORIGIN=*

# Chave da API Anthropic para análise de faturas via Claude
# Gere em: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Bot do Telegram para notificações de orçamento (80/90/100% da renda)
# Crie o bot em @BotFather e obtenha o token; chat_id é o ID do seu chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
